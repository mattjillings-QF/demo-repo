{%- render 'search',
  placeholder: block.settings.placeholder_text,
  shopify_attributes: block.shopify_attributes
-%}

{%- stylesheet -%}
  .form-search-bar input {
    border: 1px solid var(--brand-color-5);
    border-radius: 20px;
  }
  .form-search-bar input::placeholder {
    color: var(--body-color);
  }
  .form-search-bar .submit-group {
    right: 6px;
    display: flex;
    justify-content: center;
    align-items: center;
    width: 24px;
    height: 24px;
    border-radius: 50%;
    background-color: var(--brand-color-2);
  }
  .form-search-bar .submit-group svg {
    width: 12px;
    height: 12px;
    color: #fff;
  }
{%- endstylesheet -%}

{% schema %}
{
  "name": "Search Bar",
  "tag": null,
  "settings": [
    {
      "type": "text",
      "id": "placeholder_text",
      "label": "Placeholder Text",
      "default": "Search..."
    }
  ],
  "presets": [
    {
      "name": "Search Bar"
    }
  ]
}
{% endschema %}
