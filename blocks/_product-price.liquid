<div class="product-price" {{ block.shopify_attributes }}>
  {%- render 'product-variant-prices',
    product: product,
    price_format: block.settings.price_format
  -%}
</div>

{% schema %}
{
  "name": "Price",
  "tag": null,
  "settings": [
    {
      "type": "select",
      "id": "price_format",
      "label": "Price Format",
      "options": [
        {
          "value": "variant_price",
          "label": "Variant Price"
        },
        {
          "value": "from",
          "label": "From Price"
        },
        {
          "value": "range",
          "label": "Price Range"
        }
      ],
      "default": "variant_price"
    }
  ],
  "presets": [
    {
      "name": "Price"
    }
  ]
}
{% endschema %}
