{%- liquid
  # Locales
  assign recipient_email_t = 'products.product.gift_card.recipient_email' | t
  assign recipient_name_t = 'products.product.gift_card.recipient_name' | t
  assign send_date_t = 'products.product.gift_card.send_date' | t
  assign personal_message_t = 'products.product.gift_card.personal_message' | t
  assign name_placeholder_t = 'products.product.gift_card.name_placeholder' | t
  assign email_placeholder_t = 'products.product.gift_card.email_placeholder' | t
  assign send_date_placeholder_t = 'products.product.gift_card.send_date_placeholder' | t
  assign message_placeholder_t = 'products.product.gift_card.message_placeholder' | t
  assign send_as_a_gift_t = 'products.product.gift_card.send_as_a_gift' | t
-%}
<label class="select-checkbox flex align-center g-3 cursor-pointer" for="is_gift">
  <input
    show_hide_gift_card_fields
    type="checkbox"
    name="send_as_gift"
    id="is_gift"
    class="absolute opacity-0 w-0 h-0"
    checked
  >
  <div class="checkbox flex align-center flex-center">
    <svg class="check" viewBox="0 0 448 512">
      <path d="M438.6 105.4C451.1 117.9 451.1 138.1 438.6 150.6L182.6 406.6C170.1 419.1 149.9 419.1 137.4 406.6L9.372 278.6C-3.124 266.1-3.124 245.9 9.372 233.4C21.87 220.9 42.13 220.9 54.63 233.4L159.1 338.7L393.4 105.4C405.9 92.88 426.1 92.88 438.6 105.4H438.6z"/>
    </svg>
  </div>
  <div>{{ send_as_a_gift_t }}</div>
</label>
<div
  product-gift-card-fields
  class="product-gift-card-fields w-100 pb-4"
  {% if shopify_attributes != blank %}
    {{- shopify_attributes -}}
  {% endif %}
>
  <div class="gift-card-fields flex flex-col flex-wrap g-3">
    <div class="gift-card-field flex flex-wrap to-sm-flex-col g-2 flex-1">
      <div class="flex flex-col g-2 flex-1">
        <label for="recipient_name">{{ recipient_name_t }}*</label>
        <input
          property
          type="text"
          value="{{ form.name }}"
          id="recipient_name"
          placeholder="{{ name_placeholder_t }}"
          name="Recipient name"
          required
        >
      </div>
      <div class="flex flex-col g-2 flex-1">
        <label for="recipient_email">{{ recipient_email_t }}*</label>
        <input
          property
          type="email"
          value="{{ form.email }}"
          id="recipient_email"
          placeholder="{{ email_placeholder_t }}"
          name="Recipient email"
          required
        >
      </div>
    </div>
    <div
      class="gift-card-field flex flex-col g-2 to-sm-w-100"
      style="width: calc(50% - (var(--content-spacing-2) / 2));"
    >
      <label for="personal_message">{{ send_date_t }}</label>
      <input
        property
        type="date"
        value="{{ form.date }}"
        id="date"
        placeholder="{{ send_date_placeholder_t }}"
        name="Date"
        required
      >
    </div>
    <div class="gift-card-field flex flex-col g-2 flex-1">
      <label for="personal_message">{{ personal_message_t }}</label>
      <textarea
        maxlength="200"
        rows="6"
        property
        id="personal_message"
        placeholder="{{ message_placeholder_t }}"
        name="Message"
      >{{ form.message }}</textarea>
    </div>
  </div>

  <input
    send_as_gift_input
    property
    type="hidden"
    name="__shopify_send_gift_card_to_recipient"
    value="on"
  >
</div>

<script type="module">
  import { GiftCardFields } from '@theme/gift-card';
  new GiftCardFields();
</script>

{%- stylesheet -%}
  .select-checkbox .checkbox {
    width: 18px;
    height: 18px;
    border: 2px solid #ddd;
    border-radius: 3px;
    background: white;
    transition: all 0.2s ease;
  }

  .select-checkbox input[type='checkbox']:checked + .checkbox {
    border-color: var(--brand-color-1, #000);
    background: var(--brand-color-1, #000);
  }

  .select-checkbox .checkbox svg {
    width: 12px;
    height: 12px;
    opacity: 0;
    transition: opacity 0.2s ease;
  }

  .select-checkbox input[type='checkbox']:checked + .checkbox svg {
    opacity: 1;
  }

  .select-checkbox .checkbox svg path {
    fill: white;
  }
{%- endstylesheet -%}
