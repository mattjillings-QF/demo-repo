{%- comment -%}
  Renders a responsive image using a <picture> tag when both desktop and mobile images are provided.
  Supports separate focal points, responsive srcsets, and image performance optimizations like preload and lazy loading.

  @param {image} image - The desktop image
  @param {image} image_mobile - Optional. The mobile image
  @param {number} max_width - The max width for the desktop image (default: 1000)
  @param {number} mobile_width - Optional. The max width for the mobile image (default: 600)
  @param {string} alt - Optional. The alt text for the image
  @param {string} format - Optional. The image format (e.g., 'jpg', 'png'). If not provided, uses the original format.
  @param {string} class - Optional. The CSS class applied to the <img> element
  @param {boolean} preload - Optional. If true, sets fetchpriority="high"
  @param {boolean} lazy - Optional. If true, sets loading="lazy" and decoding="async"
  @param {string} context_text - Optional. Text near the image; if it matches the alt, the image is treated as decorative

  @example
  {%- render 'image',
      image: block.settings.image,
      image_mobile: block.settings.image_mobile,
      max_width: 1000,
      mobile_width: 600,
      class: 'responsive-image',
      use_placeholder: true,
      lazy: true
  -%}
{%- endcomment -%}

{%- liquid
  assign context_text = context_text | default: ''
  assign alt_image_source = image | default: image_mobile

  if alt == blank and alt_image_source
    assign alt = alt_image_source.alt
  endif

  if alt == blank and alt_image_source
    assign fallback_url = alt_image_source | image_url: width: 10
    assign fallback_name = fallback_url | split: '/' | last | split: '?' | first | split: '.' | first
    assign fallback_name = fallback_name | replace: '-', ' ' | replace: '_', ' ' | strip
    if fallback_name == blank
      assign fallback_name = 'Image'
    endif
    assign alt = fallback_name
  endif

  assign normalized_alt = alt | default: '' | strip_html | downcase | strip
  assign normalized_alt = normalized_alt | replace: '&amp;', 'and' | replace: '&', 'and'
  assign normalized_alt = normalized_alt | replace: '-', '' | replace: '_', '' | replace: ',', '' | replace: '.', '' | replace: '!', '' | replace: '?', '' | replace: ':', '' | replace: ';', '' | replace: '(', '' | replace: ')', '' | replace: '[', '' | replace: ']', '' | replace: '{', '' | replace: '}', '' | replace: '/', '' | replace: '\\', '' | replace: '"', '' | replace: "'", ''
  assign normalized_alt = normalized_alt | replace: ' ', ''

  assign normalized_context = context_text | default: '' | strip_html | downcase | strip
  assign normalized_context = normalized_context | replace: '&amp;', 'and' | replace: '&', 'and'
  assign normalized_context = normalized_context | replace: '-', '' | replace: '_', '' | replace: ',', '' | replace: '.', '' | replace: '!', '' | replace: '?', '' | replace: ':', '' | replace: ';', '' | replace: '(', '' | replace: ')', '' | replace: '[', '' | replace: ']', '' | replace: '{', '' | replace: '}', '' | replace: '/', '' | replace: '\\', '' | replace: '"', '' | replace: "'", ''
  assign normalized_context = normalized_context | replace: ' ', ''

  assign redundant_alt = false
  if normalized_alt != blank and normalized_context != blank and normalized_alt == normalized_context
    assign alt = ''
    assign redundant_alt = true
  endif

  assign max_width = max_width | plus: 0 | default: 1000
  assign mobile_width = mobile_width | plus: 0 | default: 600
  assign widths = '100,200,300,400,600,800,1000,1200,1400,1600,2000' | split: ','

  assign object_position = ''
  if image.presentation.focal_point or image_mobile.presentation.focal_point
    assign object_position = '--object-position-desktop: ' | append: image.presentation.focal_point | append: '; --object-position-mobile: ' | append: image_mobile.presentation.focal_point | append: ';'
  endif

  assign desktop_srcset = ''
  assign mobile_srcset = ''

  if image != blank
    assign desktop_srcset = ''
    for width in widths
      assign w = width | plus: 0
      if w <= max_width
        assign src = image | image_url: width: w, format: format
        assign desktop_srcset = desktop_srcset | append: src | append: ' ' | append: w | append: 'w'
        unless forloop.last
          assign desktop_srcset = desktop_srcset | append: ', '
        endunless
      endif
    endfor
  endif

  if image_mobile != blank
    assign mobile_srcset = ''
    for width in widths
      assign w = width | plus: 0
      if w <= mobile_width
        assign src = image_mobile | image_url: width: w, format: format
        assign mobile_srcset = mobile_srcset | append: src | append: ' ' | append: w | append: 'w'
        unless forloop.last
          assign mobile_srcset = mobile_srcset | append: ', '
        endunless
      endif
    endfor
  endif
-%}

{%- if image and image_mobile -%}
  <picture
    style="display:flex;"
    {% if itemprop != blank %}
      itemprop="{{ itemprop }}"
    {% endif %}
  >
    <source
      media="(min-width: 768px)"
      srcset="{{ desktop_srcset }}"
      sizes="{{ max_width }}px"
      width="{{ image.width }}"
      height="{{ image.height }}"
    >
    {%- liquid
      assign sizes = '(max-width: 767px)' | append: mobile_width | append: 'px'
      if lazy
        capture mobile_img
          echo image_mobile | image_url: width: mobile_width, format: format | image_tag: alt: alt, class: class, style: object_position, srcset: mobile_srcset, sizes: sizes, lazy: true, decoding: 'async', width: image_mobile.width, height: image_mobile.height
        endcapture
      else
        capture mobile_img
          echo image_mobile | image_url: width: mobile_width, format: format | image_tag: alt: alt, class: class, style: object_position, srcset: mobile_srcset, sizes: sizes, preload: true, fetchpriority: 'high', width: image_mobile.width, height: image_mobile.height
        endcapture
      endif
      if redundant_alt
        assign mobile_img = mobile_img | replace_first: '<img', '<img role="presentation" aria-hidden="true"'
      endif
      echo mobile_img
    -%}
  </picture>

{%- elsif image -%}
  {%- liquid
    assign max_width = max_width | append: 'px'
    if image_data_src != blank
      assign url = image | image_url: width: max_width, format: format
      capture manual_img
        echo '<img'
        if redundant_alt
          echo ' role="presentation" aria-hidden="true"'
        endif
        echo ' data-src="' | append: url | append: '" data-sizes="' | append: max_width | append: '" ' | append: ' alt="' | append: alt | append: '" class="' | append: class | append: '" style="' | append: object_position | append: '">'
      endcapture
      echo manual_img
    elsif lazy
      capture desktop_img
        echo image | image_url: width: max_width, format: format | image_tag: alt: alt, class: class, style: object_position, srcset: desktop_srcset, sizes: max_width, lazy: true, decoding: 'async', itemprop: itemprop, width: image.width, height: image.height
      endcapture
      if redundant_alt
        assign desktop_img = desktop_img | replace_first: '<img', '<img role="presentation" aria-hidden="true"'
      endif
      echo desktop_img
    else
      capture desktop_img
        echo image | image_url: width: max_width, format: format | image_tag: alt: alt, class: class, style: object_position, srcset: desktop_srcset, sizes: max_width, preload: true, fetchpriority: 'high', itemprop: itemprop, width: image.width, height: image.height
      endcapture
      if redundant_alt
        assign desktop_img = desktop_img | replace_first: '<img', '<img role="presentation" aria-hidden="true"'
      endif
      echo desktop_img
    endif
  -%}
{%- else -%}
  {%- if use_placeholder -%}
    {{ 'lifestyle-1' | placeholder_svg_tag }}
  {%- endif -%}
{%- endif -%}
