<div class="flex-center h-100 flex-col align-center">
  {%- if image != blank -%}
    <div
      class="ar-1 border-radius-circle flex-center align-center"
      style="max-width:85px;padding: 21px;background-color: var(--brand-color-2);"
    >
      {%- if lazy == true -%}
        {{-
          image
          | image_url: width: 100
          | image_tag:
            width: 100,
            height: 100,
            alt: image.alt,
            class: 'object-contain',
            loading: 'lazy',
            decoding: 'async'
        -}}
      {%- else -%}
        {{-
          image
          | image_url: width: 100
          | image_tag:
            width: 100,
            height: 100,
            alt: image.alt,
            class: 'object-contain',
            loading: 'eager',
            fetchpriority: 'high'
        -}}
      {%- endif -%}
    </div>
  {%- endif -%}

  <div class="flex flex-col align-center text-center">
    <h3>{{- heading -}}</h3>

    {%- if text != blank -%}
      <div style="max-width: 220px;">{{- text -}}</div>
    {%- endif -%}
  </div>

  {%- if button_link != blank and button_label != blank -%}
    <a href="{{- button_link -}}" aria-label="Go to {{- button_link -}}">{{- button_label -}}</a>
  {%- endif -%}
</div>
