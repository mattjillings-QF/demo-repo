{%- liquid
  assign heading = block.settings.heading
  assign heading_type = block.settings.heading_type
  assign heading_size = block.settings.heading_size
  assign content = block.settings.richtext_content
  assign open_default = block.settings.open_default
  assign id_attribute = block.settings.id_attribute

  if heading != blank and content != blank
    render 'accordion-item', question: heading, content: content, open_default: open_default, heading_tag: heading_type, heading_size: heading_size, id_attribute: id_attribute, flex_col: false, shopify_attributes: block.shopify_attributes
  endif
-%}

{% schema %}
{
  "name": "Accordion",
  "tag": null,
  "settings": [
    {
      "type": "header",
      "content": "Content"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Heading"
    },
    {
      "type": "select",
      "id": "heading_type",
      "label": "Heading Type",
      "options": [
        {
          "value": "h2",
          "label": "H2"
        },
        {
          "value": "h3",
          "label": "H3"
        }
      ],
      "default": "h2"
    },
    {
      "type": "select",
      "id": "heading_size",
      "label": "Heading Size",
      "options": [
        {
          "value": "heading-h0",
          "label": "Extra Large"
        },
        {
          "value": "heading-h1",
          "label": "Large"
        },
        {
          "value": "heading-h2",
          "label": "Medium"
        },
        {
          "value": "heading-h3",
          "label": "Small"
        }
      ],
      "default": "heading-h3"
    },
    {
      "type": "richtext",
      "id": "richtext_content",
      "label": "Rich Text Content"
    },
    {
      "type": "checkbox",
      "id": "open_default",
      "label": "Open by default",
      "default": false
    },
    {
      "type": "text",
      "id": "id_attribute",
      "label": "ID Attribute (for links)"
    }
  ],
  "presets": [
    {
      "name": "Accordion"
    }
  ]
}
{% endschema %}
