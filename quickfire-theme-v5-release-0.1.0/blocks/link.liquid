{%- liquid
  assign link = block.settings.link
  assign link_text = block.settings.link_text
  assign link_title = block.settings.link_title
  assign link_style = block.settings.link_style
  assign external_link = block.settings.external_link
-%}

{%- if link != blank and link_text != blank -%}
  <a
    href="{{ link }}"
    class="{{ link_style }} {% if link_style == 'theme-link' %}flex-center align-center{% endif %}"
    {% if external_link %}
      target="_blank" rel="noopener noreferrer"
    {% endif %}
    {% if link_title != blank %}
      title="{{ link_title }}"
    {% endif %}
    class="link"
    {{ block.shopify_attributes }}
  >
    {{ link_text }}
  </a>
{%- endif -%}

{% schema %}
{
  "name": "Link",
  "tag": null,
  "settings": [
    {
      "type": "text",
      "id": "link_text",
      "label": "Link Text",
      "default": "Link Text"
    },
    {
      "type": "url",
      "id": "link",
      "label": "Link"
    },
    {
      "type": "text",
      "id": "link_title",
      "label": "Link Title",
      "default": "Link Title"
    },
    {
      "type": "select",
      "id": "link_style",
      "label": "Link Style",
      "options": [
        {
          "value": "button-1",
          "label": "1"
        },
        {
          "value": "button-2",
          "label": "2"
        },
        {
          "value": "button-3",
          "label": "3"
        },
        {
          "value": "button-4",
          "label": "4"
        },
        {
          "value": "button-5",
          "label": "5"
        },
        {
          "value": "button-6",
          "label": "6"
        },
        {
          "value": "theme-link",
          "label": "Link"
        }
      ],
      "default": "button-1"
    },
    {
      "type": "checkbox",
      "id": "external_link",
      "label": "Open link in new tab",
      "default": false
    }
  ],
  "presets": [
    {
      "name": "Link"
    }
  ]
}
{% endschema %}
