{%- liquid
  assign has_media = false
  if product.media != blank
    assign has_media = true
  endif
  assign has_multiple_media = false
  if product.images.size > 1 and has_media
    assign has_multiple_media = true
  endif
  assign slider_class = 'main-slider-slide slider-slide'
  # assign gallery_opacity_class = 'opacity-0'
  # if product.images.size < 2 or has_media == false
  #  assign gallery_opacity_class = 'opacity-1'
  # endif
  assign main_slider_id = 'product-main-slider-' | append: section.id
  assign thumb_slider_id = 'product-thumb-slider-' | append: section.id
  assign gallery_container_id = 'product-gallery-' | append: section.id
  assign lightbox_modal_id = 'product-lightbox-' | append: section.id
  assign lightbox_slider_id = 'product-lightbox-slider-' | append: section.id
  assign lightbox_nav_id = lightbox_slider_id | append: '-nav'
  assign lightbox_heading_id = 'product-lightbox-heading-' | append: section.id
  assign main_slider_selector = '#' | append: main_slider_id
  assign thumb_orientation = 'vertical'
  if thumb_positioning == 'under'
    assign thumb_orientation = 'horizontal'
  endif
-%}

{%- assign lightbox_slide_count = 0 -%}
{%- capture lightbox_slides -%}
  {%- for media in product.media -%}
    {%- if media.media_type == 'image' -%}
      {%- assign lightbox_slide_count = lightbox_slide_count | plus: 1 -%}
      <div class="lightbox-slider-slide slider-slide" data-lightbox-index="{{ forloop.index0 }}">
        <div class="slider-zoom-container">
          {%- render 'image',
            image: media,
            max_width: 3000,
            mobile_width: 1000,
            class: 'lightbox-slider-image',
            use_placeholder: false,
            lazy: false
          -%}
        </div>
      </div>
    {%- endif -%}
  {%- endfor -%}
{%- endcapture -%}
{%- assign has_lightbox_media = false -%}
{%- if lightbox_slide_count > 0 -%}
  {%- assign has_lightbox_media = true -%}
{%- endif -%}

<div
  id="{{ gallery_container_id }}"
  gallery-container
  data-thumb-positioning="{{ thumb_positioning }}"
  data-thumb-orientation="{{ thumb_orientation }}"
  class="gallery-container gallery-layout sticky flex {% if thumb_positioning == 'under' and style == 'slider' %}flex-col-reverse{% endif %} to-md-flex-col-reverse {{ gallery_opacity_class }} h-100 {% if has_multiple_media %}g-2{% endif %}"
>
  {%- if has_multiple_media and style == 'slider' -%}
    <div class="thumb-gallery to-md-w-100 to-sm-hidden {% if thumb_positioning == 'under' and style == 'slider' %}under{% endif %}">
      {%- capture thumb_slides -%}
        {%- for media in product.media -%}
          {%- liquid
            assign lazy_load = false
            if forloop.index <= 4
              assign lazy_load = true
            endif
          -%}
          {%- case media.media_type -%}
            {%- when 'image' -%}
              <div class="thumb slider-slide w-100 h-100 overflow-hidden relative">
                <div class="gallery-image-holder border-radius w-100 h-100 overflow-hidden relative">
                  {%- if media != blank -%}
                    {%- render 'image',
                        image: media,
                        max_width: 200,
                        class: 'absolute w-100 h-100 object-cover',
                        use_placeholder: false,
                        lazy: lazy_load
                    -%}
                  {%- else -%}
                    {{ 'product-1' | placeholder_svg_tag: class: 'absolute w-100 h-100 object-cover' }}
                  {%- endif -%}
                </div>
              </div>
            {%- when 'model' -%}
              <div class="thumb slider-slide w-100 h-100 overflow-hidden relative">
                <div class="gallery-image-holder border-radius w-100 h-100 overflow-hidden relative">
                  {%- render 'image',
                      image: media.preview_image,
                      max_width: 200,
                      class: 'absolute w-100 h-100 object-cover',
                      use_placeholder: false,
                      lazy: lazy_load
                  -%}
                </div>
              </div>
            {%- when 'video' -%}
              <div class="thumb slider-slide w-100 h-100 overflow-hidden relative">
                <div class="gallery-image-holder border-radius w-100 h-100 overflow-hidden relative video">
                  {%- render 'image',
                      image: media.preview_image,
                      max_width: 200,
                      class: 'absolute w-100 h-100 object-cover',
                      use_placeholder: false,
                      lazy: lazy_load
                  -%}
                </div>
              </div>
            {%- when 'external_video' -%}
              <div class="thumb slider-slide w-100 h-100 overflow-hidden relative">
                <div class="gallery-image-holder border-radius w-100 h-100 overflow-hidden relative">
                  {%- render 'image',
                      image: media.preview_image,
                      max_width: 200,
                      class: 'absolute w-100 h-100 object-cover',
                      use_placeholder: false,
                      lazy: lazy_load
                  -%}
                </div>
              </div>
          {%- endcase -%}
        {%- endfor -%}
      {%- endcapture -%}

      <div
        id="{{ thumb_slider_id }}"
        class="blaze-slider slider thumb-slider w-100"
        data-blaze-slider
        data-thumb-gallery-slider
        data-slider-mobile="4"
        data-slider-tablet="4"
        data-slider-desktop="4"
        data-slider-wide="4"
        data-slider-gap-mobile="20"
        data-slider-gap-tablet="20"
        data-slider-gap-desktop="10"
        data-slider-gap-wide="10"
        data-slider-loop="false"
        data-slider-pagination="false"
      >
        <div class="blaze-track-container">
          <div class="blaze-track">
            {{ thumb_slides }}
          </div>
        </div>
      </div>
    </div>
  {%- endif -%}
  <div
    class="main-gallery relative {% if thumb_positioning == 'under' or style == 'grid' or has_multiple_media != true %}w-100{% else %}w-80{% endif %}"
    main-gallery
  >
    {%- render 'product-badges', product: product, limit: 2 -%}

    {%- if has_lightbox_media and product.template_suffix != 'gift-card' -%}
      <button
        type="button"
        class="gallery-lightbox-trigger border-radius-circle"
        style="background-color: #fff;"
        data-lightbox-trigger
        data-modal-trigger="{{ lightbox_modal_id }}"
        data-lightbox-main-slider="{% if has_multiple_media %}{{ main_slider_selector }}{% endif %}"
        aria-label="{{ 'products.product.open_lightbox' | t | default: 'View full-size gallery' }}"
      >
        {{ 'icon-search.svg' | inline_asset_content }}
      </button>
    {%- endif -%}

    {%- if has_media -%}
      {%- if has_multiple_media -%}
        {%- capture main_slides -%}
          {%- for media in product.media -%}
            {%- liquid
              assign lazy_load = false
              if forloop.index > 1
                assign lazy_load = true
              endif

              # DESKTOP IMAGE GRID CLASSES
              assign image_number = forloop.index
              if image_number == 1
                assign grid_class = 'span-12 first-image'
              else
                assign module_result = image_number | modulo: 5
                if module_result == 1 or module_result == 0
                  assign grid_class = 'span-6'
                else
                  assign grid_class = 'span-4'
                endif
              endif
            -%}
            {%- case media.media_type -%}
              {%- when 'image' -%}
                {%- liquid
                  assign variant_ids_for_media = ''
                  for variant in product.variants
                    assign variant_image_id = ''
                    if variant.featured_media
                      assign variant_image_id = variant.featured_media.id
                    elsif variant.featured_image
                      assign variant_image_id = variant.featured_image.id
                    elsif variant.image
                      assign variant_image_id = variant.image.id
                    endif
                    if variant_image_id == media.id
                      assign variant_ids_for_media = variant_ids_for_media | append: variant.id | append: ','
                    endif
                  endfor
                -%}
                <div class="{{ slider_class }} {{ grid_class }}" data-index="{{ forloop.index0 }}" data-id="{{ variant_ids_for_media }}" style="order: {{ forloop.index }};">
                  <div class="gallery-image-holder border-radius w-100 overflow-hidden relative pb-100">
                    {%- if media != blank -%}
                      {%- render 'image',
                          image: media,
                          max_width: 1000,
                          class: 'absolute w-100 h-100 object-cover',
                          use_placeholder: false,
                          lazy: lazy_load
                      -%}
                      {%- if style == "grid" -%}
                        <button
                          type="button"
                          class="gallery-lightbox-trigger to-sm-hidden"
                          style="inset: 0;width: 100%;height: 100%;"
                          data-slide-index="{{ forloop.index0 }}"
                          data-lightbox-trigger
                          data-modal-trigger="{{ lightbox_modal_id }}"
                          data-lightbox-main-slider="{% if has_multiple_media %}{{ main_slider_selector }}{% endif %}"
                          aria-label="{{ 'products.product.open_lightbox' | t | default: 'View full-size gallery' }}"
                        >
                          <span class="visually-hidden">{{ 'products.product.open_lightbox' | t | default: 'View full-size gallery' }}</span>
                        </button>
                      {%- endif -%}
                    {%- else -%}
                      {{ 'product-1' | placeholder_svg_tag }}
                    {%- endif -%}
                  </div>
                </div>
              {%- when 'model' -%}
                <div class="{{ slider_class }} {{ grid_class }}" data-index="{{ forloop.index0 }}" style="order: {{ forloop.index }};">
                  <div class="gallery-image-holder border-radius w-100 h-100 overflow-hidden relative">
                    {{ media | model_viewer_tag: image_size: '600x' }}
                  </div>
                </div>
              {%- when 'video' -%}
                <div class="{{ slider_class }} {{ grid_class }}" data-index="{{ forloop.index0 }}" style="order: {{ forloop.index }};">
                  <div class="gallery-image-holder border-radius w-100 h-100 overflow-hidden relative">
                    {{ media | video_tag: image_size: 600, autoplay: true, loop: true, muted: true, controls: true }}
                  </div>
                </div>
              {%- when 'external_video' -%}
                <div class="{{ slider_class }} {{ grid_class }}" data-index="{{ forloop.index0 }}" style="order: {{ forloop.index }};">
                  <div class="gallery-image-holder border-radius w-100 h-100 overflow-hidden relative">
                    {%- if media.host == 'youtube' -%}
                      {{ media | external_video_url: color: 'white' | external_video_tag }}
                    {%- elsif media.host == 'vimeo' -%}
                      {{ media | external_video_url: loop: '1', muted: '1' | external_video_tag }}
                    {%- endif -%}
                  </div>
                </div>
            {%- endcase -%}
          {%- endfor -%}
        {%- endcapture -%}

        <div
          main-gallery-slider
          id="{{ main_slider_id }}"
          data-product-id="{{ product.id }}"
          class="blaze-slider main-slider w-100 h-auto"
          data-blaze-slider
          data-slider-mobile="1"
          data-slider-tablet="1"
          data-slider-desktop="1"
          data-slider-wide="1"
          data-slider-gap-mobile="8"
          data-slider-gap-tablet="8"
          data-slider-gap-desktop="8"
          data-slider-gap-wide="8"
          data-slider-pagination="true"
          data-slider-loop="false"
        >
          <div class="blaze-track-container">
            <div class="blaze-track">
              {{ main_slides }}
            </div>
          </div>
          <div class="blaze-pagination slider-pagination g-1 flex-center relative mt-4"></div>
        </div>

        {%- if has_multiple_media -%}
          <script
            src="{{ 'product-gallery-slider.js' | asset_url }}"
            type="module"
            fetchpriority="low"
          ></script>
        {%- endif -%}

        {%- if style == 'grid' and has_multiple_media -%}
          <script
            src="{{ 'product-gallery.js' | asset_url }}"
            type="module"
            fetchpriority="low"
          ></script>
        {%- endif -%}
      {%- else -%}
        {%- comment -%} Single media item - no slider needed {%- endcomment -%}
        {%- for media in product.media limit: 1 -%}
          {%- case media.media_type -%}
            {%- when 'image' -%}
              <div class="gallery-image-holder border-radius w-100 overflow-hidden relative pb-100">
                {%- if media != blank -%}
                  {%- render 'image',
                    image: media,
                    max_width: 1000,
                    class: 'absolute w-100 h-100 object-cover',
                    use_placeholder: false,
                    lazy: false
                  -%}
                {%- else -%}
                  {{ 'product-1' | placeholder_svg_tag }}
                {%- endif -%}
              </div>
            {%- when 'model' -%}
              <div class="gallery-image-holder border-radius w-100 h-100 overflow-hidden relative">
                {{ media | model_viewer_tag: image_size: '600x' }}
              </div>
            {%- when 'video' -%}
              <div class="gallery-image-holder border-radius w-100 h-100 overflow-hidden relative">
                {{
                  media
                  | video_tag:
                    image_size: 600,
                    autoplay: true,
                    loop: true,
                    muted: true,
                    controls: true
                }}
              </div>
            {%- when 'external_video' -%}
              <div class="gallery-image-holder border-radius w-100 h-100 overflow-hidden relative">
                {%- if media.host == 'youtube' -%}
                  {{ media | external_video_url: color: 'white' | external_video_tag }}
                {%- elsif media.host == 'vimeo' -%}
                  {{ media | external_video_url: loop: '1', muted: '1' | external_video_tag }}
                {%- endif -%}
              </div>
          {%- endcase -%}
        {%- endfor -%}
      {%- endif -%}
    {%- else -%}
      <div class="gallery-image-holder border-radius w-100 overflow-hidden relative pb-100">
        {{ 'product-1' | placeholder_svg_tag }}
      </div>
    {%- endif -%}
  </div>
</div>

{%- if has_lightbox_media -%}
  <div
    class="product-lightbox-modal"
    data-modal="{{ lightbox_modal_id }}"
    data-lightbox-modal
    aria-hidden="true"
    role="dialog"
    aria-modal="true"
    aria-labelledby="{{ lightbox_heading_id }}"
    style="display: none;"
  >
    <div
      class="product-lightbox-modal__overlay"
      data-modal-close="{{ lightbox_modal_id }}"
      aria-hidden="true"
    ></div>
    <div
      class="product-lightbox-modal__content section-container border-radius-large shadow"
      data-modal-panel
    >
      <header class="product-lightbox-modal__header flex align-center flex-between g-3">
        {% comment %} <h2 id="{{ lightbox_heading_id }}" class="product-lightbox-modal__title">{{ product.title | escape }}</h2> {% endcomment %}
        <button
          type="button"
          class="product-lightbox-modal__close"
          aria-label="{{ 'accessibility.close_modal' | t | default: 'Close' }}"
          data-modal-close="{{ lightbox_modal_id }}"
        >
          {{ 'icon--close.svg' | inline_asset_content }}
        </button>
        <div
          slot="container-end"
          id="{{ lightbox_nav_id }}"
          class="product-gallery-navigation lightbox-navigation"
        >
          {%- render 'slider-navigation' -%}
        </div>
      </header>
      <div class="product-lightbox-modal__body">
        <div class="flex flex-col">
          <div
            thumb-gallery-slider
            id="{{ lightbox_slider_id }}"
            class="blaze-slider slider lightbox-slider"
            data-blaze-slider
            data-slider-mobile="1"
            data-slider-tablet="1"
            data-slider-desktop="1"
            data-slider-wide="1"
            data-slider-gap-mobile="10"
            data-slider-gap-tablet="10"
            data-slider-gap-desktop="10"
            data-slider-gap-wide="10"
            data-slider-loop="false"
            data-slider-pagination="false"
            data-lightbox-slide-count="{{ lightbox_slide_count }}"
          >
            <div class="blaze-track-container">
              <div class="blaze-track">
                {{ lightbox_slides | strip }}
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
{%- endif -%}

{%- stylesheet -%}
  @media only screen and (min-width: 768px) {
    #main-product .main-slider .slider-pagination {
      display: none;
    }
  }

  @media only screen and (max-width: 767.98px) {
    .gallery-image-holder .variant-image-wrapper {
      display: none;
    }
  }

  .gallery-lightbox-trigger {
    position: absolute;
    top: var(--content-spacing-2);
    right: var(--content-spacing-2);
    z-index: 2;
    display: inline-flex;
    justify-content: center;
    align-items: center;
    width: 44px;
    height: 44px;
    border: 0;

    /* border-radius: 50%; */

    /* background: rgba(17, 17, 17, 0.55); */
    color: #fff;
    cursor: pointer;
    transition:
      background 0.2s ease,
      transform 0.2s ease;
  }

  .gallery-lightbox-trigger:hover,
  .gallery-lightbox-trigger:focus {
    outline: none;

    /* background: rgba(17, 17, 17, 0.85); */
    transform: scale(1.05);
  }

  .gallery-lightbox-trigger svg {
    display: block;
    width: 20px;
    height: 20px;

    /* fill: currentColor; */
    pointer-events: none;
  }

  .product-lightbox-modal {
    display: none;
    padding: clamp(12px, 3vw, 32px);
  }

  .product-lightbox-modal__content {
    display: flex;
    flex-direction: column;
    gap: clamp(12px, 2vw, 24px);
    max-width: min(1100px, 90vw);
    margin: 5vh auto;
    padding: clamp(16px, 3vw, 32px);
  }

  .product-lightbox-modal__title {
    margin: 0;
    font-size: clamp(1.1rem, 2vw, 1.5rem);
    font-weight: 600;
    letter-spacing: 0.02em;
  }

  .product-lightbox-modal__close {
    display: inline-flex;
    justify-content: center;
    align-items: center;
    width: 40px;
    height: 40px;
    border: 0;
    color: inherit;

    /* border-radius: 50%; */

    /* background: rgba(17, 17, 17, 0.65); */
    cursor: pointer;
    transition:
      background 0.2s ease,
      transform 0.2s ease;
  }

  .product-lightbox-modal__close:hover,
  .product-lightbox-modal__close:focus {
    outline: none;

    /* background: rgba(17, 17, 17, 0.85); */
    transform: scale(1.05);
  }

  .product-lightbox-modal__close svg {
    display: block;
    width: 18px;
    height: 18px;
    pointer-events: none;
    fill: currentcolor;
  }

  .product-lightbox-modal__body {
    position: relative;
  }

  .lightbox-slider {
    width: 100%;
    height: min(65vh, 420px);
  }

  .lightbox-slider .slider-slide {
    display: flex;
    justify-content: center;
    align-items: center;
    background: #0b0b0b;
  }

  .lightbox-slider .slider-zoom-container {
    width: 100%;
    height: 100%;
  }

  .lightbox-slider-image {
    width: 100%;
    height: 100%;
    object-fit: contain;
  }

  /* .lightbox-navigation {
  position: absolute;
  top: 50%;
  width: 100%;
  padding: 0 clamp(1rem, 3vw, 2.5rem);
} */

  #main-product-container #main-product .gallery .gallery-container {
    top: 105px;
    transition: all 0.3s;
  }

  .main-slider .slider-slide {
    height: auto;
    aspect-ratio: 1 / 1;
  }

  /* Single media item styles */
  .main-gallery .gallery-image-holder {
    aspect-ratio: 1 / 1;
  }

  .thumb-slider {
    width: 100%;
    height: auto;
  }

  .thumb-slider .slider-slide {
    aspect-ratio: 1 / 1;
  }

  #main-product-container
    #main-product
    .gallery
    .gallery-container
    .main-gallery
    .gallery-image-holder
    video,
  #main-product-container
    #main-product
    .gallery
    .gallery-container
    .main-gallery
    .gallery-image-holder
    iframe,
  #main-product-container
    #main-product
    .gallery
    .gallery-container
    .main-gallery
    .gallery-image-holder
    model-viewer,
  #main-product-container
    #main-product
    .gallery
    .gallery-container
    .main-gallery
    .gallery-image-holder
    svg:not([lightbox-trigger] svg) {
    position: absolute;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  @media only screen and (min-width: 768px) {
    .gallery-container[data-thumb-orientation='vertical'] .thumb-slider {
      height: 100%;
      max-height: 100%;
      overflow: hidden !important;
    }

    .gallery-container[data-thumb-orientation='vertical'] .thumb-slider .blaze-track-container {
      height: 100%;
      padding-right: 2px;
      overflow: hidden auto;
      cursor: grab;
      touch-action: pan-y;
    }

    .gallery-container[data-thumb-orientation='vertical']
      .thumb-slider
      .blaze-track-container.thumb-dragging {
      cursor: grabbing;
      user-select: none;
    }

    .gallery-container[data-thumb-orientation='vertical'] .thumb-slider .blaze-track {
      display: flex;
      flex-direction: column;
      gap: 10px;
      transform: none !important;
      will-change: auto;
    }

    .gallery-container[data-thumb-orientation='vertical'] .thumb-slider .blaze-track > * {
      flex: 0 0 auto;
      width: 100% !important;
    }

    .gallery-container[data-thumb-orientation='vertical'] .thumb-slider .thumb {
      width: 100%;
      height: auto;
      aspect-ratio: 1 / 1;
    }
  }

  #main-product-container
    #main-product
    .gallery
    .gallery-container
    .main-gallery
    .gallery-image-holder
    video,
  #main-product-container
    #main-product
    .gallery
    .gallery-container
    .main-gallery
    .gallery-image-holder
    iframe,
  #main-product-container
    #main-product
    .gallery
    .gallery-container
    .main-gallery
    .gallery-image-holder
    model-viewer,
  #main-product-container
    #main-product
    .gallery
    .gallery-container
    .main-gallery
    .gallery-image-holder
    svg:not([lightbox-trigger] svg) {
    position: absolute;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  @media only screen and (min-width: 768px) {
    .thumb-gallery {
      flex-shrink: 0; /* Prevent growing */
      width: calc(20% - var(--content-spacing-3));
      height: auto; /* Let JavaScript control the height */
      overflow: hidden;
    }

    .thumb-gallery.under {
      width: 100%;
    }

    .thumb-gallery.under .thumb-slider {
      height: 100px;
    }

    .thumb-gallery.under .thumb-slider .blaze-track {
      height: 100px;
    }

    .thumb-slider {
      overflow: hidden !important;
    }

    .gallery-lightbox-trigger {
      top: 0.75rem;
      right: 0.75rem;
      width: 38px;
      height: 38px;
    }

    .thumb-slider .slider-slide {
      width: auto;
      height: auto;
      aspect-ratio: 1 / 1;
    }

    .lightbox-slider {
      height: min(66vh, 860px);
    }

    #main-product-container #main-product .gallery .gallery-container {
      top: 105px;
      transition: all 0.3s;
    }

    .thumb-slider .slider-slide {
      height: auto;
      aspect-ratio: 1 / 1;
    }

    .main-slider .variant-image-wrapper {
      display: none;
    }

    .variant-image-wrapper.attached-false {
      display: none !important;
    }

    .main-slider .slider-slide .gallery-image-holder {
      border: 1px solid var(--brand-color-5);
      background-color: #fff;
    }
    .main-slider .variant-image-wrapper.active {
      display: block;
    }

    .main-slider .slider-slide .first-image .gallery-image-holder:has(.active) > img {
      display: none;
    }

    /* Single media item styles */
    .main-gallery .gallery-image-holder {
      aspect-ratio: 1 / 1;
    }

    /* Desktop styles applied when JavaScript adds 'desktop' class to slider-container */
    .main-gallery .main-slider.desktop .blaze-track {
      display: grid;
      gap: clamp(
        var(--grid-gap-mobile),
        calc(var(--grid-intercept) + var(--grid-slope) * 1vw),
        var(--grid-gap)
      );
      grid-template-columns: repeat(12, 1fr);
    }

    .main-gallery .main-slider .main-slider-slide {
      flex-shrink: 0 !important;
    }

