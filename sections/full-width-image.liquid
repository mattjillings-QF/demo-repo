{%- liquid
  assign img = section.settings.image
  assign link_url = section.settings.url_link
  assign link_label = section.settings.link_label
  assign preserve_dimensions = section.settings.preserve_image_dimensions
  assign desktop_max_height = section.settings.desktop_height_setting
  assign mobile_max_height = section.settings.mobile_height_setting
  assign lazy_load = section.settings.lazy_load
  assign page_width = section.settings.page_width
  assign vertical_spacing = section.settings.vertical_spacing
  assign custom_spacing = section.settings.custom_spacing
  assign top_spacing = section.settings.top_spacing
  assign bottom_spacing = section.settings.bottom_spacing
  assign top_spacing_mobile = section.settings.top_spacing_mobile
  assign bottom_spacing_mobile = section.settings.bottom_spacing_mobile

  assign label = link_label | default: img.alt

  if img == blank
    assign desktop_max_height = 0
    assign mobile_max_height = 0
  endif
-%}

{% if link_url != blank %}
  <a
    href="{{ link_url }}"
    aria-label="{{ label }}"
    class="full-width-image-container flex {% if preserve_dimensions %}preserve-dimensions{% endif %} {% unless custom_spacing %}{{ vertical_spacing }}{% else %}custom-spacing{% endunless %} {{ page_width }}"
    style="
      {%- if custom_spacing -%}
        {%- if vertical_spacing == 'vertical-padding' -%}
          padding-top: {{ top_spacing }}px; padding-bottom: {{ bottom_spacing }}px;--mobile-padding-top: {{ top_spacing_mobile }}px; --mobile-padding-bottom: {{ bottom_spacing_mobile }}px;
        {%- elsif vertical_spacing == 'vertical-margin' -%}
          margin-top: {{ top_spacing }}px; margin-bottom: {{ bottom_spacing }}px;--mobile-margin-top: {{ top_spacing_mobile }}px; --mobile-margin-bottom: {{ bottom_spacing_mobile }}px;
        {%- elsif vertical_spacing == 'vertical-margin vertical-padding' -%}
          padding-top: {{ top_spacing }}px; padding-bottom: {{ bottom_spacing }}px; margin-top: {{ top_spacing }}px; margin-bottom: {{ bottom_spacing }}px; --mobile-padding-top: {{ top_spacing_mobile }}px; --mobile-padding-bottom: {{ bottom_spacing_mobile }}px; --mobile-margin-top: {{ top_spacing_mobile }}px; --mobile-margin-bottom: {{ bottom_spacing_mobile }}px;
        {%- endif -%}
      {%- endif -%}
      --desktop-max-height: {{ desktop_max_height }}px; --mobile-max-height: {{ mobile_max_height }}px;
    "
  >
    {%- render 'image',
      image: img,
      max_width: 2000,
      use_placeholder: true,
      lazy: lazy_load,
      class: 'border-radius'
    -%}
  </a>
{% else %}
  <div
    class="full-width-image-container flex {% if preserve_dimensions %}preserve-dimensions{% endif %} {% unless custom_spacing %}{{ vertical_spacing }}{% else %}custom-spacing{% endunless %} {{ page_width }}"
    style="
      {%- if custom_spacing -%}
        {%- if vertical_spacing == 'vertical-padding' -%}
          padding-top: {{ top_spacing }}px; padding-bottom: {{ bottom_spacing }}px;--mobile-padding-top: {{ top_spacing_mobile }}px; --mobile-padding-bottom: {{ bottom_spacing_mobile }}px;
        {%- elsif vertical_spacing == 'vertical-margin' -%}
          margin-top: {{ top_spacing }}px; margin-bottom: {{ bottom_spacing }}px;--mobile-margin-top: {{ top_spacing_mobile }}px; --mobile-margin-bottom: {{ bottom_spacing_mobile }}px;
        {%- elsif vertical_spacing == 'vertical-margin vertical-padding' -%}
          padding-top: {{ top_spacing }}px; padding-bottom: {{ bottom_spacing }}px; margin-top: {{ top_spacing }}px; margin-bottom: {{ bottom_spacing }}px; --mobile-padding-top: {{ top_spacing_mobile }}px; --mobile-padding-bottom: {{ bottom_spacing_mobile }}px; --mobile-margin-top: {{ top_spacing_mobile }}px; --mobile-margin-bottom: {{ bottom_spacing_mobile }}px;
        {%- endif -%}
      {%- endif -%}
      --desktop-max-height: {{ desktop_max_height }}px; --mobile-max-height: {{ mobile_max_height }}px;
    "
  >
    {%- render 'image',
      image: img,
      max_width: 2000,
      use_placeholder: true,
      lazy: lazy_load,
      class: 'border-radius'
    -%}
  </div>
{% endif %}

{%- stylesheet -%}
  .full-width-image .full-width-image-container {
    width: 100%;
    height: var(--desktop-max-height, 200px);
    overflow: hidden;
  }

  @media only screen and (max-width: 767.98px) {
    .full-width-image .full-width-image-container {
      height: var(--mobile-max-height, 200px);
    }
  }

  .full-width-image .full-width-image-container img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .full-width-image .full-width-image-container.preserve-dimensions {
    height: auto;
  }

  .full-width-image .full-width-image-container.preserve-dimensions img {
    width: 100%;
    height: 100%;
    object-fit: contain;
  }
{%- endstylesheet -%}

{% schema %}
{
  "name": "Full Width Image",
  "tag": "section",
  "class": "full-width-image",
  "settings": [
    {
      "type": "image_picker",
      "id": "image",
      "label": "Image"
    },
    {
      "type": "url",
      "id": "url_link",
      "label": "Link",
      "info": "Optional URL to make the image clickable."
    },
    {
      "type": "text",
      "id": "link_label",
      "label": "Link Label Text",
      "info": "Optional text for the link (for accessibility)."
    },
    {
      "type": "checkbox",
      "id": "preserve_image_dimensions",
      "label": "Preserve Image Dimensions",
      "default": false
    },
    {
      "type": "range",
      "id": "desktop_height_setting",
      "label": "Desktop Height (in pixels)",
      "min": 100,
      "max": 500,
      "step": 10,
      "unit": "px",
      "default": 200,
      "visible_if": "{{ section.settings.preserve_image_dimensions == false }}"
    },
    {
      "type": "range",
      "id": "mobile_height_setting",
      "label": "Mobile Height (in pixels)",
      "min": 100,
      "max": 500,
      "step": 10,
      "unit": "px",
      "default": 200,
      "visible_if": "{{ section.settings.preserve_image_dimensions == false }}"
    },
    {
      "type": "checkbox",
      "id": "lazy_load",
      "label": "Lazy Load",
      "default": false
    },
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "select",
      "id": "page_width",
      "label": "Page Width",
      "options": [
        {
          "value": "page-width",
          "label": "Default"
        },
        {
          "value": "page-width--narrow",
          "label": "Narrow"
        },
        {
          "value": "page-width--wide",
          "label": "Wide"
        },
        {
          "value": "page-width--full",
          "label": "Full Width"
        }
      ],
      "default": "page-width"
    },
    {
      "type": "select",
      "id": "vertical_spacing",
      "label": "Vertical Spacing",
      "options": [
        {
          "value": "vertical-margin",
          "label": "Margin"
        },
        {
          "value": "vertical-padding",
          "label": "Padding"
        },
        {
          "value": "vertical-margin vertical-padding",
          "label": "Margin and Padding"
        },
        {
          "value": "",
          "label": "None"
        }
      ],
      "default": "vertical-margin",
      "info": "This uses the global spacing settings from the theme settings to ensure consistent spacing between sections. If you want to use custom spacing, please check the 'Custom Spacing' option."
    },
    {
      "type": "checkbox",
      "id": "custom_spacing",
      "label": "Custom Spacing",
      "default": false
    },
    {
      "type": "range",
      "id": "top_spacing",
      "label": "Top Spacing",
      "min": 0,
      "max": 120,
      "step": 5,
      "unit": "px",
      "default": 120,
      "visible_if": "{{ section.settings.custom_spacing == true }}"
    },
    {
      "type": "range",
      "id": "bottom_spacing",
      "label": "Bottom Spacing",
      "min": 0,
      "max": 120,
      "step": 5,
      "unit": "px",
      "default": 120,
      "visible_if": "{{ section.settings.custom_spacing == true }}"
    },
    {
      "type": "range",
      "id": "top_spacing_mobile",
      "label": "Mobile Top Spacing",
      "min": 0,
      "max": 120,
      "step": 5,
      "unit": "px",
      "default": 60,
      "visible_if": "{{ section.settings.custom_spacing == true }}"
    },
    {
      "type": "range",
      "id": "bottom_spacing_mobile",
      "label": "Mobile Bottom Spacing",
      "min": 0,
      "max": 120,
      "step": 5,
      "unit": "px",
      "default": 60,
      "visible_if": "{{ section.settings.custom_spacing == true }}"
    }
  ],
  "presets": [
    {
      "name": "Full Width Image",
      "category": "Media"
    }
  ]
}
{% endschema %}
