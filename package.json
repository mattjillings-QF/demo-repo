{
  "name": "quickfire-theme-v5",
  "version": "1.0.0",
  "description": "<h1 align=\"center\" style=\"position: relative;\">   <br>     <img src=\"./assets/shoppy-x-ray.svg\" alt=\"logo\" width=\"200\">   <br>   Shopify Skeleton Theme </h1>",
  "main": "index.js",
  "type": "module",
  "scripts": {
    "dev": "shopify theme dev --store bunker-storage-eu",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "theme:check": "shopify theme check",
    "lint:css": "stylelint \"**/*.{css,liquid}\"",
    "lint:css:fix": "stylelint \"**/*.{css,liquid}\" --fix",
    "lint:js": "eslint \"**/*.{js,jsx,ts,tsx}\"",
    "lint:js:fix": "eslint \"**/*.{js,jsx,ts,tsx}\" --fix",
    "lint:all": "npm run format && npm run lint:css && npm run lint:js && npm run theme:check",
    "lint:all:fix": "npm run format && npm run lint:css:fix && npm run lint:js:fix && npm run theme:check",
    "verify": "npm run format:check && npm run lint:css && npm run lint:js && npm run theme:check",
    "prepare": "husky"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Quickfire-Digital/quickfire-theme-v5.git"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/Quickfire-Digital/quickfire-theme-v5/issues"
  },
  "homepage": "https://github.com/Quickfire-Digital/quickfire-theme-v5#readme",
  "devDependencies": {
    "@shopify/prettier-plugin-liquid": "^1.10.0",
    "eslint": "^9.39.1",
    "globals": "^16.5.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.2.6",
    "postcss-html": "^1.8.0",
    "prettier": "^3.6.2",
    "stylelint": "^16.25.0",
    "stylelint-config-standard": "^39.0.1",
    "stylelint-order": "^7.0.0"
  },
  "lint-staged": {
    "*.{liquid,css,scss,js,jsx,ts,tsx,json,md,yml,yaml}": [
      "prettier --write"
    ],
    "*.{css,liquid}": [
      "stylelint --fix --allow-empty-input"
    ],
    "*.js": [
      "eslint --fix"
    ]
  }
}
